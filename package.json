{
  "name": "plant-taxonomy-field-guide",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "server": "node backend/server.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/data/validateCatalog.test.ts tests/data/dichotomousKey.test.ts tests/search/searchService.test.ts tests/db/sqliteSeed.test.ts",
    "data:download-images": "node --import tsx scripts/download-plant-images.ts",
    "data:fetch-stages": "node --import tsx scripts/fetch-inaturalist-stages.ts",
    "data:validate": "node --import tsx scripts/validate-catalog.ts",
    "data:export-backend": "node --import tsx scripts/export-backend-data.ts",
    "db:smoke": "node --import tsx scripts/sqlite-smoke.ts"
  },
  "dependencies": {
    "expo": "~55.0.23",
    "expo-constants": "~55.0.16",
    "expo-file-system": "~55.0.19",
    "expo-image": "~55.0.10",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.14",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "~55.0.17",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "twrnc": "^4.16.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "~19.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  }
}
